@page "/export"
@rendermode InteractiveServer
@inject IExportService ExportService
@inject UserStateService UserState
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<h1 style="margin-bottom:24px;font-size:2rem;font-weight:600;color:var(--text)">Exportar Dados</h1>

<div style="padding:24px;box-shadow:0 2px 8px rgba(0,0,0,0.15);border-radius:8px;background:var(--surface);margin-bottom:24px">
    <div style="display:flex;flex-wrap:wrap;gap:24px">
        <div style="flex:1 1 calc(50% - 12px);min-width:300px">
            <div style="padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.1);border-radius:8px;background:var(--surface);margin-bottom:16px">
                <h3 style="margin-bottom:12px;font-size:1.25rem;font-weight:500;color:var(--text)">PDF de Dados (Backup)</h3>
                <p style="margin-bottom:12px;color:var(--text-secondary);line-height:1.5">
                    Gera um PDF com dados estruturados (JSON) para importação futura ou transferência entre máquinas.
                </p>
                <select style="width:100%;padding:12px 14px;border:1px solid var(--border);border-radius:4px;font-size:16px;font-family:inherit;background:var(--surface);color:var(--text);margin-bottom:12px"
                        value="@_dataScope" @onchange="OnDataScopeChanged">
                    <option value="1">Apenas Tarefas</option>
                    <option value="2">Apenas Notas</option>
                    <option value="3">Sistema Completo</option>
                </select>
                <button style="padding:10px 24px;background:var(--primary);color:#fff;border:none;border-radius:4px;font-size:14px;font-weight:500;cursor:pointer;opacity:@(_isExporting ? "0.6" : "1")"
                        @onclick="ExportDataPdf" disabled="@_isExporting">
                    Gerar PDF de Dados
                </button>
            </div>
        </div>

        <div style="flex:1 1 calc(50% - 12px);min-width:300px">
            <div style="padding:16px;box-shadow:0 1px 4px rgba(0,0,0,0.1);border-radius:8px;background:var(--surface);margin-bottom:16px">
                <h3 style="margin-bottom:12px;font-size:1.25rem;font-weight:500;color:var(--text)">PDF de Visualização (Impressão)</h3>
                <p style="margin-bottom:12px;color:var(--text-secondary);line-height:1.5">
                    Gera um PDF com layout visual para leitura humana ou impressão física.
                </p>
                <select style="width:100%;padding:12px 14px;border:1px solid var(--border);border-radius:4px;font-size:16px;font-family:inherit;background:var(--surface);color:var(--text);margin-bottom:12px"
                        value="@_visualScope" @onchange="OnVisualScopeChanged">
                    <option value="1">Apenas Tarefas</option>
                    <option value="2">Apenas Notas</option>
                    <option value="3">Sistema Completo</option>
                </select>
                <button style="padding:10px 24px;background:#546e7a;color:#fff;border:none;border-radius:4px;font-size:14px;font-weight:500;cursor:pointer;opacity:@(_isExporting ? "0.6" : "1")"
                        @onclick="ExportVisualPdf" disabled="@_isExporting">
                    Gerar PDF Visual
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private int _dataScope = 3;
    private int _visualScope = 3;
    private bool _isExporting;

    private void OnDataScopeChanged(ChangeEventArgs e) => _dataScope = int.Parse(e.Value?.ToString() ?? "3");
    private void OnVisualScopeChanged(ChangeEventArgs e) => _visualScope = int.Parse(e.Value?.ToString() ?? "3");

    private async Task ExportDataPdf()
    {
        if (UserState.CurrentUser is null) return;
        _isExporting = true;
        try
        {
            var request = new ExportRequestDto
            {
                Scope = _dataScope,
                IsVisualExport = false,
                OwnerId = UserState.CurrentUser.Id,
                OwnerName = UserState.CurrentUser.FullName
            };
            var pdfBytes = await ExportService.ExportDataPdfAsync(request);
            await DownloadFile(pdfBytes, $"TaskFlow_Data_{DateTime.Now:yyyyMMdd_HHmmss}.pdf");
            Snackbar.Add("PDF de dados gerado com sucesso.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
        }
    }

    private async Task ExportVisualPdf()
    {
        if (UserState.CurrentUser is null) return;
        _isExporting = true;
        try
        {
            var request = new ExportRequestDto
            {
                Scope = _visualScope,
                IsVisualExport = true,
                OwnerId = UserState.CurrentUser.Id,
                OwnerName = UserState.CurrentUser.FullName
            };
            var pdfBytes = await ExportService.ExportVisualPdfAsync(request);
            await DownloadFile(pdfBytes, $"TaskFlow_Report_{DateTime.Now:yyyyMMdd_HHmmss}.pdf");
            Snackbar.Add("PDF de visualização gerado com sucesso.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isExporting = false;
        }
    }

    private async Task DownloadFile(byte[] bytes, string fileName)
    {
        var base64 = Convert.ToBase64String(bytes);
        await JS.InvokeVoidAsync("downloadFile", base64, fileName);
    }
}
