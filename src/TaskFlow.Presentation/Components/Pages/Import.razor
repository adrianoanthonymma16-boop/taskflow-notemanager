@page "/import"
@rendermode InteractiveServer
@inject IImportService ImportService
@inject UserStateService UserState
@inject ISnackbar Snackbar

<h1 style="margin-bottom:24px;font-size:2rem;font-weight:600;color:var(--text)">Importar Dados</h1>

<div style="padding:24px;box-shadow:0 2px 8px rgba(0,0,0,0.15);border-radius:8px;background:var(--surface);margin-bottom:24px">
    <h3 style="margin-bottom:16px;font-size:1.25rem;font-weight:500;color:var(--text)">Upload de PDF para Importação</h3>

    <select style="width:100%;padding:12px 14px;border:1px solid var(--border);border-radius:4px;font-size:16px;font-family:inherit;background:var(--surface);color:var(--text);margin-bottom:12px"
            value="@_conflictStrategy" @onchange="OnConflictChanged">
        <option value="0">Substituir (limpa e recria)</option>
        <option value="1">Mesclar (atualiza + insere)</option>
        <option value="2">Anexar (só insere novos)</option>
    </select>

    <label style="display:flex;align-items:center;gap:8px;cursor:pointer;margin-bottom:12px;font-size:16px;color:var(--text)">
        <input type="checkbox" checked="@_filterByDate" @onchange="OnFilterByDateChanged" />
        Filtrar por período
    </label>

    @if (_filterByDate)
    {
        <div style="display:flex;gap:12px;margin-bottom:12px">
            <input type="date" value="@(_startDate?.ToString("yyyy-MM-dd") ?? "")"
                   @onchange="OnStartDateChanged"
                    style="flex:1;padding:12px;border:1px solid var(--border);border-radius:4px;font-size:16px;font-family:inherit;background:var(--surface);color:var(--text)" />
            <input type="date" value="@(_endDate?.ToString("yyyy-MM-dd") ?? "")"
                    @onchange="OnEndDateChanged"
                    style="flex:1;padding:12px;border:1px solid var(--border);border-radius:4px;font-size:16px;font-family:inherit;background:var(--surface);color:var(--text)" />
        </div>
    }

    <label style="display:inline-flex;align-items:center;gap:8px;padding:10px 24px;background:var(--primary);color:#fff;border:none;border-radius:4px;font-size:14px;font-weight:500;cursor:pointer;opacity:@(_isImporting ? "0.6" : "1")">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="margin-right:4px"><path d="M9 16h6v-6h4l-7-7-7 7h4zm-4 2h14v2H5z"/></svg>
        Selecionar PDF e Importar
        <InputFile Accept=".pdf" OnChange="OnFileSelected" disabled="@_isImporting" style="display:none" />
    </label>

    @if (_isImporting)
    {
        <div style="margin-top:12px;height:4px;background:var(--border);border-radius:2px;overflow:hidden">
            <div style="height:100%;width:30%;background:var(--primary);animation:indeterminate 1.5s ease-in-out infinite;border-radius:2px"></div>
        </div>
    }
</div>

<style>
    @@keyframes indeterminate {
        0% { margin-left: -30%; width: 30%; }
        50% { margin-left: 35%; width: 30%; }
        100% { margin-left: 100%; width: 0%; }
    }
</style>

@code {
    private int _conflictStrategy = 1;
    private bool _filterByDate;

    private void OnConflictChanged(ChangeEventArgs e) => _conflictStrategy = int.Parse(e.Value?.ToString() ?? "1");
    private DateTime? _startDate;
    private DateTime? _endDate;
    private bool _isImporting;

    private DateTime? ParseDate(string? value)
    {
        if (DateTime.TryParse(value, out var d)) return d;
        return null;
    }

    private void OnFilterByDateChanged(ChangeEventArgs e) => _filterByDate = e.Value is bool b && b;
    private void OnStartDateChanged(ChangeEventArgs e) => _startDate = ParseDate(e.Value?.ToString());
    private void OnEndDateChanged(ChangeEventArgs e) => _endDate = ParseDate(e.Value?.ToString());

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0 || UserState.CurrentUser is null) return;

        _isImporting = true;
        try
        {
            var file = e.File;
            var buffer = new byte[file.Size];
            await file.OpenReadStream(50 * 1024 * 1024).ReadAsync(buffer);

            var request = new ImportRequestDto
            {
                FileBytes = buffer,
                FileName = file.Name,
                ConflictStrategy = _conflictStrategy,
                FilterByDate = _filterByDate,
                StartDate = _startDate,
                EndDate = _endDate,
                OwnershipAction = 0
            };

            var result = await ImportService.ImportDataPdfAsync(UserState.CurrentUser.Id, request);

            if (result.Message == "OWNERSHIP_CONFLICT")
            {
                request.OwnershipAction = await ShowOwnershipDialog();
                if (request.OwnershipAction == 0)
                {
                    Snackbar.Add("Importação cancelada.", Severity.Info);
                    return;
                }
                result = await ImportService.ImportDataPdfAsync(UserState.CurrentUser.Id, request);
            }

            if (result.Success)
                Snackbar.Add(result.Message, Severity.Success);
            else
                Snackbar.Add(result.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isImporting = false;
        }
    }

    private async Task<int> ShowOwnershipDialog()
    {
        var dialog = await DialogService.ShowMessageBox(
            "Conflito de Propriedade",
            "Os dados deste PDF pertencem a outro usuário. O que deseja fazer?",
            yesText: "Integrar (adotar dados)",
            cancelText: "Visualizar (Modo B)",
            options: new DialogOptions { MaxWidth = MaxWidth.Small });
        return dialog == true ? 1 : 2;
    }

    [Inject] private IDialogService DialogService { get; set; } = default!;
}
