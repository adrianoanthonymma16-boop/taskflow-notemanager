@if (Visible)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:9999;display:flex;align-items:center;justify-content:center" @onclick="Cancel">
        <div style="background:var(--surface,#fff);border-radius:12px;max-width:500px;width:95%;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,0.3)" @onclick:stopPropagation>
            <h3 style="margin:0 0 16px 0;font-size:1.2rem">@(IsEdit ? "✏️ Editar Nota" : "➕ Nova Nota")</h3>

            <p style="margin:0 0 4px 0;font-size:0.85rem;color:var(--text-secondary,#666)">Título *</p>
            <input @bind="_model.Title" style="width:100%;padding:12px;border:1px solid var(--border,#e0e0e0);border-radius:6px;font-size:0.95rem;font-family:inherit;box-sizing:border-box;margin-bottom:12px" required />

            <p style="margin:0 0 4px 0;font-size:0.85rem;color:var(--text-secondary,#666)">Conteúdo</p>
            <textarea @bind="_model.Content" style="width:100%;padding:12px;border:1px solid var(--border,#e0e0e0);border-radius:6px;font-size:0.95rem;font-family:inherit;resize:vertical;min-height:120px;box-sizing:border-box;margin-bottom:12px"></textarea>

            <p style="margin:0 0 4px 0;font-size:0.85rem;color:var(--text-secondary,#666)">Status</p>
            <select @bind="_model.Status" style="width:100%;padding:12px;border:1px solid var(--border,#e0e0e0);border-radius:6px;font-size:0.95rem;font-family:inherit;box-sizing:border-box;margin-bottom:12px">
                <option value="0">Rascunho</option>
                <option value="1">Publicado</option>
                <option value="2">Arquivado</option>
            </select>

            <hr style="border:none;border-top:1px solid var(--border,#e0e0e0);margin:16px 0" />
            <div style="display:flex;justify-content:flex-end;gap:8px">
                <button @onclick="Cancel" style="padding:8px 20px;border:1px solid var(--border,#e0e0e0);border-radius:6px;cursor:pointer;font-size:0.9rem;background:transparent">Cancelar</button>
                <button @onclick="Submit" style="padding:8px 20px;border:none;border-radius:6px;cursor:pointer;font-size:0.9rem;background:#1976d2;color:#fff">@(IsEdit ? "Salvar" : "Criar")</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public CreateNoteDto Model { get; set; } = new();
    [Parameter] public bool IsEdit { get; set; }
    [Parameter] public EventCallback<CreateNoteDto> OnSubmit { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private CreateNoteDto _model = new();

    protected override void OnParametersSet()
    {
        _model = new CreateNoteDto
        {
            Title = Model.Title,
            Content = Model.Content,
            Status = Model.Status
        };
    }

    private async Task Submit()
    {
        await OnSubmit.InvokeAsync(_model);
    }

    private async Task Cancel()
    {
        await OnCancel.InvokeAsync();
    }
}
