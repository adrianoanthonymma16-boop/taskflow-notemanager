@rendermode InteractiveServer
@inject INoteService NoteService
@inject UserStateService UserState
@inject ISnackbar Snackbar

@if (Visible)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:9999;display:flex;align-items:center;justify-content:center" @onclick="OnBackdropClick">
        <div style="background:var(--surface,#fff);border-radius:12px;max-width:800px;width:95%;max-height:90vh;overflow-y:auto;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,0.3)" @onclick:stopPropagation>

            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px">
                <h2 style="margin:0;font-size:1.5rem;display:flex;align-items:center;gap:8px;font-weight:600">
                    <span style="font-size:0.8rem;padding:4px 12px;border-radius:16px;font-weight:500;background:var(--mud-palette-table-lines,#e0e0e0);color:var(--text-secondary,#666)">#@Note.NoteNumber</span>
                    @Note.Title
                </h2>
                <span style="font-size:0.8rem;padding:4px 14px;border-radius:16px;font-weight:500;background:@GetStatusBg(Note.Status);color:@GetStatusText(Note.Status)">@Note.StatusName</span>
            </div>

            <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">Criado em</p>
            <p style="margin:2px 0 8px 0">@Note.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>

            @if (Note.UpdatedAt.HasValue)
            {
                <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">Atualizado em</p>
                <p style="margin:2px 0 12px 0">@Note.UpdatedAt?.ToString("dd/MM/yyyy HH:mm")</p>
            }

            @if (!string.IsNullOrWhiteSpace(Note.Content))
            {
                <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">Conteúdo</p>
                <div style="padding:16px;margin:4px 0 16px 0;background:var(--mud-palette-table-lines,#f5f5f5);border-radius:10px;min-height:100px">
                    <p style="margin:0;white-space:pre-wrap;line-height:1.6">@Note.Content</p>
                </div>
            }

            <hr style="border:none;border-top:1px solid var(--border,#e0e0e0);margin:16px 0" />

            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
                <h3 style="font-size:1.1rem;margin:0;display:flex;align-items:center;gap:6px">📎 Anexos (@Note.Attachments.Count)</h3>
                <label style="padding:6px 14px;border:1px solid var(--border,#e0e0e0);border-radius:6px;cursor:pointer;font-size:0.85rem;display:inline-flex;align-items:center;gap:4px;background:var(--surface,#fff)">
                    ➕ Adicionar
                    <InputFile OnChange="OnFilesSelected" accept=".pdf,.doc,.docx" multiple style="display:none" />
                </label>
            </div>

            @if (_isUploading)
            {
                <progress style="width:100%;height:4px;margin-bottom:12px;border-radius:2px" value="" max="100"></progress>
            }

            @if (Note.Attachments.Count == 0)
            {
                <div style="padding:24px;text-align:center;border:2px dashed var(--border,#e0e0e0);border-radius:10px">
                    <p style="margin:0;font-size:2rem">📄</p>
                    <p style="margin:8px 0 0 0;font-size:0.9rem;color:var(--text-secondary,#666)">Nenhum anexo adicionado</p>
                </div>
            }
            else
            {
                <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:8px">
                    @foreach (var att in Note.Attachments)
                    {
                        <div style="padding:12px;border:1px solid var(--border,#e0e0e0);border-radius:8px;display:flex;align-items:center;gap:8px;background:var(--surface,#fff)">
                            <div style="flex:1;min-width:0">
                                <p style="margin:0;font-size:0.85rem;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:500">@att.FileName</p>
                                <p style="margin:0;font-size:0.75rem;color:var(--text-secondary,#666)">@att.FileSizeFormatted</p>
                            </div>
                            <button @onclick="() => RemoveAttachment(att)" style="padding:4px;border:none;border-radius:4px;cursor:pointer;background:transparent;color:#d32f2f;font-size:1rem;line-height:1">🗑️</button>
                        </div>
                    }
                </div>
            }

            <hr style="border:none;border-top:1px solid var(--border,#e0e0e0);margin:16px 0" />

            <div style="display:flex;justify-content:space-between;align-items:center">
                <button @onclick="DeleteNoteAction" style="padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:0.9rem;background:#d32f2f;color:#fff;display:flex;align-items:center;gap:6px">
                    🗑️ Excluir
                </button>
                <button @onclick="() => Close()" style="padding:8px 16px;border:1px solid var(--border,#e0e0e0);border-radius:6px;cursor:pointer;font-size:0.9rem;background:transparent;color:var(--text,#333)">
                    ❌ Fechar
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public NoteDto Note { get; set; } = new();
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _isUploading;

    private async Task OnFilesSelected(InputFileChangeEventArgs e)
    {
        if (UserState.CurrentUser is null) return;
        _isUploading = true;
        try
        {
            foreach (var file in e.GetMultipleFiles())
            {
                var stream = file.OpenReadStream(50 * 1024 * 1024);
                var att = await NoteService.AddAttachmentAsync(Note.Id, UserState.CurrentUser.Id,
                    file.Name, file.ContentType, file.Size, stream);

                if (att is not null)
                    Note.Attachments.Add(att);
            }
            Snackbar.Add("Anexos adicionados.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isUploading = false;
        }
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private async Task RemoveAttachment(AttachmentDto attachment)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Remover anexo '{attachment.FileName}'?"))
        {
            await NoteService.RemoveAttachmentAsync(attachment.Id);
            Note.Attachments.Remove(attachment);
            Snackbar.Add("Anexo removido.", Severity.Success);
        }
    }

    private async Task DeleteNoteAction()
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Excluir nota '{Note.Title}'?"))
        {
            await NoteService.DeleteAsync(Note.Id);
            Snackbar.Add("Nota excluída.", Severity.Success);
            await Close();
        }
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    private async Task OnBackdropClick()
    {
        await Close();
    }

    private string GetStatusBg(int status) => status switch
    {
        0 => "#f5f5f5",
        1 => "#e8f5e9",
        2 => "#ede7f6",
        _ => "#f5f5f5"
    };

    private string GetStatusText(int status) => status switch
    {
        0 => "#333",
        1 => "#2e7d32",
        2 => "#4527a0",
        _ => "#333"
    };
}
