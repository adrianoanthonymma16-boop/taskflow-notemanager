@rendermode InteractiveServer
@inject IJSRuntime JS

@if (Visible)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:10000;display:flex;align-items:center;justify-content:center" @onclick="() => Cancel()">
        <div style="background:var(--surface,#fff);border-radius:12px;max-width:500px;width:95%;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,0.3)" @onclick:stopPropagation>
            <h3 style="margin:0 0 16px 0;display:flex;align-items:center;gap:8px;font-size:1.2rem">
                ⚠️ Registrar Pendência
            </h3>

            <p style="margin:0 0 4px 0;font-size:0.85rem;color:var(--text-secondary,#666)">Motivo da Pendência *</p>
            <textarea @bind="_model.Reason" style="width:100%;padding:12px;border:1px solid var(--border,#e0e0e0);border-radius:6px;font-size:0.95rem;font-family:inherit;resize:vertical;min-height:80px;box-sizing:border-box;background:var(--surface,#fff);color:var(--text,#333)" required></textarea>

            <p style="margin:12px 0 4px 0;font-size:0.85rem;color:var(--text-secondary,#666)">Nome da Contraparte (opcional)</p>
            <input @bind="_model.CounterpartyName" style="width:100%;padding:12px;border:1px solid var(--border,#e0e0e0);border-radius:6px;font-size:0.95rem;font-family:inherit;box-sizing:border-box;background:var(--surface,#fff);color:var(--text,#333)" />

            <p style="margin:16px 0 4px 0;font-size:0.85rem">Sua Assinatura</p>
            <div style="position:relative;border:2px dashed var(--border,#e0e0e0);border-radius:8px;overflow:hidden;margin-bottom:8px;background:var(--surface,#fff);touch-action:none">
                <canvas id="@_sigCanvas" style="width:100%;height:140px;display:block;cursor:crosshair;touch-action:none"></canvas>
                <p style="margin:0;position:absolute;bottom:4px;right:8px;color:var(--text-secondary,#666);font-size:11px">Desenhe sua assinatura</p>
            </div>
            <button @onclick="() => ClearCanvas(_sigCanvas)" style="padding:4px 12px;border:1px solid var(--border,#e0e0e0);border-radius:4px;cursor:pointer;font-size:0.8rem;background:transparent;margin-bottom:16px">🔄 Limpar Assinatura</button>

            <p style="margin:12px 0 4px 0;font-size:0.85rem">
                Assinatura da Contraparte
                @if (!string.IsNullOrWhiteSpace(_model.CounterpartyName))
                {
                    <span>(@_model.CounterpartyName)</span>
                }
                <span style="color:var(--text-secondary,#666);font-size:0.8rem">(opcional)</span>
            </p>
            <div style="position:relative;border:2px dashed var(--border,#e0e0e0);border-radius:8px;overflow:hidden;margin-bottom:8px;background:var(--surface,#fff);touch-action:none">
                <canvas id="@_counterCanvas" style="width:100%;height:140px;display:block;cursor:crosshair;touch-action:none"></canvas>
                <p style="margin:0;position:absolute;bottom:4px;right:8px;color:var(--text-secondary,#666);font-size:11px">Desenhe a assinatura da contraparte</p>
            </div>
            <button @onclick="() => ClearCanvas(_counterCanvas)" style="padding:4px 12px;border:1px solid var(--border,#e0e0e0);border-radius:4px;cursor:pointer;font-size:0.8rem;background:transparent;margin-bottom:16px">🔄 Limpar Assinatura</button>

            <hr style="border:none;border-top:1px solid var(--border,#e0e0e0);margin:16px 0" />

            <div style="display:flex;justify-content:flex-end;gap:8px">
                <button @onclick="Cancel" style="padding:8px 20px;border:1px solid var(--border,#e0e0e0);border-radius:6px;cursor:pointer;font-size:0.9rem;background:transparent">Cancelar</button>
                <button @onclick="Submit" style="padding:8px 20px;border:none;border-radius:6px;cursor:pointer;font-size:0.9rem;background:#f57c00;color:#fff;display:flex;align-items:center;gap:6px">⚠️ Marcar Pendência</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public CreatePendingLogDto Model { get; set; } = new();
    [Parameter] public EventCallback OnClose { get; set; }

    private CreatePendingLogDto _model = new();
    private readonly string _sigCanvas = $"sig-{Guid.NewGuid():N}";
    private readonly string _counterCanvas = $"sig-ctr-{Guid.NewGuid():N}";

    protected override void OnParametersSet()
    {
        _model = Model;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("signaturePad.init", _sigCanvas);
            await JS.InvokeVoidAsync("signaturePad.init", _counterCanvas);
        }
    }

    private async Task ClearCanvas(string id)
    {
        await JS.InvokeVoidAsync("signaturePad.clear", id);
    }

    private async Task Submit()
    {
        _model.MySignature = await JS.InvokeAsync<string>("signaturePad.getData", _sigCanvas);
        _model.CounterpartySignature = await JS.InvokeAsync<string>("signaturePad.getData", _counterCanvas);
        _submitted = true;
        await OnClose.InvokeAsync();
    }

    private async Task Cancel()
    {
        _submitted = false;
        await OnClose.InvokeAsync();
    }

    private bool _submitted;
    public bool WasSubmitted => _submitted;
}
