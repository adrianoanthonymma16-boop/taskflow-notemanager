@page "/recover-password"
@rendermode InteractiveServer
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-16">
    <MudPaper Elevation="3" Class="pa-8">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-6">Recuperar Senha</MudText>

        @switch (_step)
        {
            case 1:
                <EditForm Model="_step1Model" OnValidSubmit="CheckUsername">
                    <DataAnnotationsValidator />
                    <MudTextField @bind-Value="_step1Model.Username" Label="Usuário" Variant="Variant.Outlined"
                                  Required="true" Class="mb-4" />
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                               FullWidth="true" Disabled="_isLoading">
                        Continuar
                    </MudButton>
                </EditForm>
                break;

            case 2:
                <MudText Class="mb-4"><strong>Pergunta de segurança:</strong> @_securityQuestion</MudText>
                <EditForm Model="_step2Model" OnValidSubmit="CheckAnswer">
                    <DataAnnotationsValidator />
                    <MudTextField @bind-Value="_step2Model.Answer" Label="Sua Resposta" Variant="Variant.Outlined"
                                  Required="true" Class="mb-4" />
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary"
                               FullWidth="true" Disabled="_isLoading">
                        Verificar
                    </MudButton>
                </EditForm>
                break;

            case 3:
                <EditForm Model="_step3Model" OnValidSubmit="ResetPassword">
                    <DataAnnotationsValidator />
                    <MudTextField @bind-Value="_step3Model.NewPassword" Label="Nova Senha" InputType="InputType.Password"
                                  Variant="Variant.Outlined" Required="true" Class="mb-3" />
                    <MudTextField @bind-Value="_step3Model.ConfirmPassword" Label="Confirmar Nova Senha" InputType="InputType.Password"
                                  Variant="Variant.Outlined" Required="true" Class="mb-4" />
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Success"
                               FullWidth="true" Disabled="_isLoading">
                        Redefinir Senha
                    </MudButton>
                </EditForm>
                break;
        }

        <div class="mt-4">
            <MudButton Variant="Variant.Text" Color="Color.Secondary" OnClick='() => Navigation.NavigateTo("/login")'>
                Voltar ao Login
            </MudButton>
        </div>
    </MudPaper>
</MudContainer>

@code {
    private int _step = 1;
    private bool _isLoading;
    private string? _securityQuestion;
    private string _recoverUsername = string.Empty;

    private class Step1Model { public string Username { get; set; } = string.Empty; }
    private class Step2Model { public string Answer { get; set; } = string.Empty; }
    private class Step3Model
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string NewPassword { get; set; } = string.Empty;
        [System.ComponentModel.DataAnnotations.Required]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    private Step1Model _step1Model = new();
    private Step2Model _step2Model = new();
    private Step3Model _step3Model = new();

    private async Task CheckUsername()
    {
        _isLoading = true;
        try
        {
            var question = await AuthService.GetSecurityQuestionAsync(_step1Model.Username);
            if (question is null)
            {
                Snackbar.Add("Usuário não encontrado.", Severity.Error);
                return;
            }
            _recoverUsername = _step1Model.Username;
            _securityQuestion = question;
            _step = 2;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task CheckAnswer()
    {
        _isLoading = true;
        try
        {
            var dto = new RecoverPasswordDto
            {
                Username = _recoverUsername,
                SecurityAnswer = _step2Model.Answer,
                NewPassword = "temp",
                ConfirmNewPassword = "temp"
            };

            var question = await AuthService.GetSecurityQuestionAsync(dto.Username);
            _step = 3;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ResetPassword()
    {
        if (_step3Model.NewPassword != _step3Model.ConfirmPassword)
        {
            Snackbar.Add("As senhas não conferem.", Severity.Error);
            return;
        }

        _isLoading = true;
        try
        {
            var dto = new RecoverPasswordDto
            {
                Username = _recoverUsername,
                SecurityAnswer = _step2Model.Answer,
                NewPassword = _step3Model.NewPassword,
                ConfirmNewPassword = _step3Model.ConfirmPassword
            };

            var success = await AuthService.RecoverPasswordAsync(dto);
            if (success)
            {
                Snackbar.Add("Senha redefinida com sucesso!", Severity.Success);
                Navigation.NavigateTo("/login");
            }
            else
            {
                Snackbar.Add("Resposta de segurança incorreta.", Severity.Error);
                _step = 1;
            }
        }
        finally
        {
            _isLoading = false;
        }
    }
}
