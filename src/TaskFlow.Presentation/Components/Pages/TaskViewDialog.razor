@rendermode InteractiveServer
@inject ITaskService TaskService
@inject UserStateService UserState
@inject ISnackbar Snackbar

@if (Visible)
{
    <div style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.5);z-index:9999;display:flex;align-items:center;justify-content:center" @onclick="OnBackdropClick">
        <div style="background:var(--surface,#fff);border-radius:12px;max-width:720px;width:95%;max-height:90vh;overflow-y:auto;padding:24px;box-shadow:0 20px 60px rgba(0,0,0,0.3)" @onclick:stopPropagation>

            <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px">
                <h2 style="margin:0;font-size:1.5rem;font-weight:600">@Task.Title</h2>
                <span style="font-size:0.8rem;padding:4px 14px;border-radius:16px;font-weight:500;background:@GetStatusBg(Task.Status);color:@GetStatusText(Task.Status)">@Task.StatusName</span>
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:16px">
                <div>
                    <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">Data de Criação</p>
                    <p style="margin:4px 0 12px 0">@Task.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                    <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">Prazo</p>
                    <p style="margin:4px 0 0 0">
                        @(Task.DueDate?.ToString("dd/MM/yyyy") ?? "Sem prazo definido")
                        @if (Task.DueDate.HasValue && Task.Status < 2)
                        {
                            var days = (Task.DueDate.Value.Date - DateTime.Today).Days;
                            if (days < 0)
                            {
                                <span style="font-size:0.75rem;padding:2px 10px;border-radius:12px;margin-left:8px;background:#fce4e4;color:#d32f2f">Atrasada há @(-days) dia(s)</span>
                            }
                            else if (days == 0)
                            {
                                <span style="font-size:0.75rem;padding:2px 10px;border-radius:12px;margin-left:8px;background:#fff3e0;color:#f57c00">Vence hoje</span>
                            }
                        }
                    </p>
                </div>
                <div>
                    <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">Última Atualização</p>
                    <p style="margin:4px 0 12px 0">@(Task.UpdatedAt?.ToString("dd/MM/yyyy HH:mm") ?? "—")</p>
                    @if (Task.PendingLogs.Any(pl => pl.IsActive))
                    {
                        <div style="padding:8px 12px;font-size:0.85rem;border-radius:6px;background:#fff3e0;color:#f57c00;display:flex;align-items:center;gap:6px">
                            <span>⚠️</span>
                            <span>Esta tarefa possui uma pendência ativa</span>
                        </div>
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Task.Description))
            {
                <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">Descrição</p>
                <div style="padding:12px;margin:4px 0 16px 0;background:var(--mud-palette-table-lines,#f5f5f5);border-radius:8px">
                    <p style="margin:0;white-space:pre-wrap">@Task.Description</p>
                </div>
            }

            <hr style="border:none;border-top:1px solid var(--border,#e0e0e0);margin:16px 0" />

            <div style="display:flex;gap:8px;flex-wrap:wrap">
                @if (Task.Status == 0)
                {
                    <button @onclick="OpenPendingDialog" style="padding:8px 20px;border:none;border-radius:6px;cursor:pointer;font-size:0.9rem;background:#f57c00;color:#fff;display:flex;align-items:center;gap:6px">
                        ⚠️ Marcar Pendência
                    </button>
                    <button @onclick="CompleteTask" style="padding:8px 20px;border:none;border-radius:6px;cursor:pointer;font-size:0.9rem;background:#43a047;color:#fff;display:flex;align-items:center;gap:6px">
                        ✅ Concluir
                    </button>
                }
                @if (Task.Status == 1)
                {
                    <button @onclick="ResolvePending" style="padding:8px 20px;border:none;border-radius:6px;cursor:pointer;font-size:0.9rem;background:#f57c00;color:#fff;display:flex;align-items:center;gap:6px">
                        ❌ Remover Pendência
                    </button>
                }
                @if (Task.Status == 2)
                {
                    <button @onclick="ReopenTask" style="padding:8px 20px;border:none;border-radius:6px;cursor:pointer;font-size:0.9rem;background:#1565c0;color:#fff;display:flex;align-items:center;gap:6px">
                        ↩️ Reabrir
                    </button>
                }
            </div>

            @if (Task.PendingLogs.Count > 0)
            {
                <hr style="border:none;border-top:1px solid var(--border,#e0e0e0);margin:20px 0" />
                <h3 style="font-size:1.1rem;margin:0 0 12px 0;display:flex;align-items:center;gap:6px">📋 Histórico de Pendências</h3>

                @foreach (var log in Task.PendingLogs.OrderByDescending(l => l.CreatedAt))
                {
                    <div style="padding:16px;margin-bottom:12px;border-radius:10px;border:1px solid var(--border,#e0e0e0);background:var(--surface,#fff)">
                        <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
                            <div style="width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;background:@(log.IsActive ? "#fff3e0" : "#e8f5e9");color:@(log.IsActive ? "#f57c00" : "#43a047");font-size:0.9rem">
                                @(log.IsActive ? "⚠️" : "✅")
                            </div>
                            <div>
                                <p style="margin:0;font-weight:600;font-size:0.9rem">@(log.IsActive ? "Pendência Ativa" : "Pendência Resolvida")</p>
                                <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">
                                    @if (log.IsActive)
                                    {
                                        <span>Aberta em @log.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                                    }
                                    else
                                    {
                                        <span>Resolvida em @log.ResolvedAt?.ToString("dd/MM/yyyy HH:mm")</span>
                                    }
                                </p>
                            </div>
                        </div>

                        <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">Registrado por</p>
                        <p style="margin:2px 0 8px 0">@log.OwnerName</p>

                        <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">Motivo</p>
                        <div style="padding:8px;margin:2px 0 8px 0;background:var(--mud-palette-table-lines,#f5f5f5);border-radius:6px">
                            <p style="margin:0">@log.Reason</p>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(log.CounterpartyName))
                        {
                            <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">Contraparte</p>
                            <p style="margin:2px 0 8px 0">@log.CounterpartyName</p>
                        }

                        @if (!string.IsNullOrWhiteSpace(log.MySignature) || !string.IsNullOrWhiteSpace(log.CounterpartySignature))
                        {
                            <div style="display:grid;grid-template-columns:1fr 1fr;gap:12px">
                                @if (!string.IsNullOrWhiteSpace(log.MySignature))
                                {
                                    <div>
                                        <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">Assinatura (emissor)</p>
                                        <div style="border:1px solid var(--border,#e0e0e0);border-radius:6px;overflow:hidden;background:#fff;max-width:240px">
                                            <img src="@log.MySignature" alt="Assinatura" style="display:block;width:100%;height:80px;object-fit:contain" />
                                        </div>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(log.CounterpartySignature))
                                {
                                    <div>
                                        <p style="margin:0;font-size:0.8rem;color:var(--text-secondary,#666)">Assinatura (contraparte)</p>
                                        <div style="border:1px solid var(--border,#e0e0e0);border-radius:6px;overflow:hidden;background:#fff;max-width:240px">
                                            <img src="@log.CounterpartySignature" alt="Assinatura contraparte" style="display:block;width:100%;height:80px;object-fit:contain" />
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }

            <hr style="border:none;border-top:1px solid var(--border,#e0e0e0);margin:16px 0" />

            <div style="display:flex;justify-content:space-between;align-items:center">
                <button @onclick="DeleteTaskAction" style="padding:8px 16px;border:none;border-radius:6px;cursor:pointer;font-size:0.9rem;background:#d32f2f;color:#fff;display:flex;align-items:center;gap:6px">
                    🗑️ Excluir
                </button>
                <button @onclick="() => Close()" style="padding:8px 16px;border:1px solid var(--border,#e0e0e0);border-radius:6px;cursor:pointer;font-size:0.9rem;background:transparent;color:var(--text,#333)">
                    ❌ Fechar
                </button>
            </div>
        </div>
    </div>

    @if (_showPendingSubDialog)
    {
        <PendingDialog Visible="true" Model="@_pendingDto" OnClose="@OnPendingSubDialogClosed" />
    }
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public TaskDto Task { get; set; } = new();
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _showPendingSubDialog;
    private CreatePendingLogDto _pendingDto = new();

    private async Task OpenPendingDialog()
    {
        _pendingDto = new CreatePendingLogDto { TaskId = Task.Id };
        _showPendingSubDialog = true;
    }

    private async Task OnPendingSubDialogClosed()
    {
        _showPendingSubDialog = false;
        if (UserState.CurrentUser is not null && !string.IsNullOrWhiteSpace(_pendingDto.Reason))
        {
            await TaskService.MarkAsPendingAsync(UserState.CurrentUser.Id, _pendingDto);
            Snackbar.Add("Tarefa marcada como pendente.", Severity.Warning);
        }
        await Close();
    }

    private async Task CompleteTask()
    {
        try
        {
            await TaskService.MarkAsCompletedAsync(Task.Id);
            Snackbar.Add("Tarefa concluída.", Severity.Success);
            await Close();
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }

    private async Task ResolvePending()
    {
        await TaskService.ResolvePendingAsync(Task.Id);
        Snackbar.Add("Pendência removida. Tarefa reaberta.", Severity.Success);
        await Close();
    }

    private async Task ReopenTask()
    {
        await TaskService.ReopenAsync(Task.Id);
        Snackbar.Add("Tarefa reaberta.", Severity.Success);
        await Close();
    }

    private async Task DeleteTaskAction()
    {
        if (await JS.InvokeAsync<bool>("confirm", $"Excluir tarefa '{Task.Title}'?"))
        {
            await TaskService.DeleteAsync(Task.Id);
            Snackbar.Add("Tarefa excluída.", Severity.Success);
            await Close();
        }
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }

    private async Task OnBackdropClick()
    {
        await Close();
    }

    private string GetStatusBg(int status) => status switch
    {
        0 => "#e3f2fd",
        1 => "#fff3e0",
        2 => "#e8f5e9",
        _ => "#f5f5f5"
    };

    private string GetStatusText(int status) => status switch
    {
        0 => "#1565c0",
        1 => "#f57c00",
        2 => "#2e7d32",
        _ => "#333"
    };
}
