@page "/visual-pdfs"
@rendermode InteractiveServer
@inject IVisualPdfRecordRepository VisualRepo
@inject UserStateService UserState
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<h1 style="margin-bottom:16px;font-size:2rem;font-weight:600;color:var(--text)">PDFs Visuais (Modo B)</h1>

<p style="margin-bottom:16px;color:var(--text-secondary);line-height:1.5">
    PDFs importados para leitura visual, sem integração com seus dados.
</p>

<label style="display:inline-flex;align-items:center;gap:8px;padding:10px 24px;background:var(--primary);color:#fff;border:none;border-radius:4px;font-size:14px;font-weight:500;cursor:pointer;opacity:@(_isUploading ? "0.6" : "1");margin-bottom:16px">
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="margin-right:4px"><path d="M9 16h6v-6h4l-7-7-7 7h4zm-4 2h14v2H5z"/></svg>
    Importar PDF para Leitura
    <InputFile Accept=".pdf" OnChange="OnFileImported" disabled="@_isUploading" style="display:none" />
</label>

@if (_records.Count == 0)
{
    <div style="padding:12px 16px;background:#e3f2fd;color:#1565c0;border-radius:4px;font-size:14px">
        Nenhum PDF visual importado.
    </div>
}
else
{
    <div style="overflow-x:auto;background:var(--surface);border-radius:8px;box-shadow:0 1px 4px rgba(0,0,0,0.1)">
        <table style="width:100%;border-collapse:collapse;font-size:14px">
            <thead>
                <tr style="border-bottom:2px solid var(--border)">
                    <th style="padding:12px 16px;text-align:left;font-weight:600;color:var(--text)">Arquivo</th>
                    <th style="padding:12px 16px;text-align:left;font-weight:600;color:var(--text)">Escopo</th>
                    <th style="padding:12px 16px;text-align:left;font-weight:600;color:var(--text)">Externo</th>
                    <th style="padding:12px 16px;text-align:left;font-weight:600;color:var(--text)">Importado em</th>
                    <th style="padding:12px 16px;text-align:left;font-weight:600;color:var(--text)">Ações</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var context in _records)
                {
                    var idx = _records.IndexOf(context);
                    <tr style="border-bottom:1px solid var(--border);@(idx % 2 == 1 ? "background:rgba(0,0,0,0.03)" : "")">
                        <td style="padding:12px 16px;color:var(--text)">@context.OriginalFileName</td>
                        <td style="padding:12px 16px;color:var(--text)">@context.SourceScopeName</td>
                        <td style="padding:12px 16px">
                            <strong style="font-size:12px;color:@(context.IsExternal ? "#e65100" : "#1565c0")">
                                @(context.IsExternal ? "Sim" : "Não")
                            </strong>
                        </td>
                        <td style="padding:12px 16px;color:var(--text)">@context.ImportedAt.ToString("dd/MM/yyyy HH:mm")</td>
                        <td style="padding:12px 16px;white-space:nowrap">
                            <button @onclick="() => ViewPdf(context.Id)"
                                    style="padding:6px;background:none;border:none;border-radius:50%;cursor:pointer;color:var(--text);font-size:18px;line-height:1"
                                    title="Visualizar">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/></svg>
                            </button>
                            <button @onclick="() => DeleteRecord(context.Id)"
                                    style="padding:6px;background:none;border:none;border-radius:50%;cursor:pointer;color:#d32f2f;font-size:18px;line-height:1"
                                    title="Remover">
                                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"/></svg>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<VisualPdfRecordDto> _records = new();
    private bool _isUploading;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecords();
    }

    private async Task LoadRecords()
    {
        if (UserState.CurrentUser is null) return;
        var records = await VisualRepo.GetByOwnerAsync(UserState.CurrentUser.Id);
        _records = records.Select(r => new VisualPdfRecordDto
        {
            Id = r.Id,
            OriginalFileName = r.OriginalFileName,
            SourceScope = (int)r.SourceScope,
            SourceScopeName = r.SourceScope.ToString(),
            IsExternal = r.IsExternal,
            UserDescription = r.UserDescription,
            ImportedAt = r.ImportedAt
        }).ToList();
    }

    private async Task OnFileImported(InputFileChangeEventArgs e)
    {
        if (e.FileCount == 0 || UserState.CurrentUser is null) return;
        _isUploading = true;
        try
        {
            foreach (var file in e.GetMultipleFiles())
            {
                var buffer = new byte[file.Size];
                await file.OpenReadStream(50 * 1024 * 1024).ReadAsync(buffer);
                await ImportService.VisualImportAsync(UserState.CurrentUser.Id, buffer, file.Name);
            }
            await LoadRecords();
            Snackbar.Add("PDF importado para leitura visual.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Erro: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isUploading = false;
        }
    }

    private void ViewPdf(int id)
    {
        Snackbar.Add("Visualizador de PDF será implementado.", Severity.Info);
    }

    private async Task DeleteRecord(int id)
    {
        var confirmed = await DialogService.ShowMessageBox(
            "Confirmar", "Remover este registro?", yesText: "Sim", cancelText: "Não");
        if (confirmed == true)
        {
            await VisualRepo.DeleteAsync(id);
            await LoadRecords();
            Snackbar.Add("Registro removido.", Severity.Success);
        }
    }

    [Inject] private IImportService ImportService { get; set; } = default!;
    [Inject] private IDialogService DialogService { get; set; } = default!;
}
